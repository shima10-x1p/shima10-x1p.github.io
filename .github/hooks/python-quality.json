{
  "version": 1,
  "hooks": {
    "postToolUse": [
      {
        "type": "command",
        "bash": "./.github/scripts/copilot-post-edit.sh",
        "powershell": "powershell -ExecutionPolicy Bypass -File .\\.github\\scripts\\copilot-post-edit.ps1",
